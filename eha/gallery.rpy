screen gallery_navigation():

    ## Change with your image

    add "images/nightparkk.webp"

    vbox:
        style_prefix "gallery_nav"

        ## Gallery Navigation to Character A, Character B and Character C gallery.
        textbutton _("Scribbles") action Show("gallery_s")
        textbutton _("Aiden") action Show("gallery_a")
        textbutton _("NSFW Aiden") action Show("gallery_aa")
        textbutton _("Dallan") action Show("gallery_b")
        textbutton _("NSFW Dallan") action Show("gallery_bb")
        textbutton _("Tate") action Show("gallery_c")
        textbutton _("NSFW Tate") action Show("gallery_cc")
        textbutton _("Therium") action Show("gallery_t")
        textbutton _("NSFW Therium") action Show("gallery_tt")
        textbutton _("Alvy") action Show("gallery_al")
        textbutton _("NSFW Alvy") action Show("gallery_all")
        textbutton _("Chibis") action Show("gallery_ch")




    textbutton _("Return") action [Return(), Hide("gallery_navigation")] xalign 0.97 yalign 0.95

## The position of the vertical box containing the gallery navigation buttons
style gallery_nav_vbox:
    xalign 0.01
    yalign 0.5
    spacing 10


screen gallery_al():

    default cg_page_al = 1

    zorder 100
    tag menu


    hbox:
        style_prefix "gallery_stuff"


        ## Our buttons for the pages of Character A's Gallery section.
        textbutton _("1") action SetLocalVariable("cg_page_al", 1)
        



    showif cg_page_al == 1:
        grid 3 3:

            style_prefix "gallery_stuff"

            ## Replace one null with one button created according to this structure:
            ## add Transform(g.make_button("CG_Button_Name", "path/Unlocked_Thumbnail.png", "path/Locked_Thumbnail.png")
            add Transform(g.make_button("CGal1_Button", "images/tn/horseball.webp", "images/gallery_locked.webp"), xsize=500, ysize=281)

            add Transform(g.make_button("CGal2_Button", "images/tn/fishing.webp","images/gallery_locked.webp"), xsize=500, ysize=281)
            add Transform(g.make_button("CGal3_Button", "images/tn/terrydinner1.webp","images/gallery_locked.webp"), xsize=500, ysize=281)
            add Transform(g.make_button("CGal4_Button", "images/tn/hornyjail1.webp","images/gallery_locked.webp"), xsize=500, ysize=281)
            add Transform(g.make_button("CGal5_Button", "images/tn/hotelroom2.webp","images/gallery_locked.webp"), xsize=500, ysize=281)
            add Transform(g.make_button("CGal6_Button", "images/tn/alvydream1.webp","images/gallery_locked.webp"), xsize=500, ysize=281)
            add Transform(g.make_button("CGal7_Button", "images/tn/alvycg6.webp","images/gallery_locked.webp"), xsize=500, ysize=281)
            if persistent.unlocked_alvydream3:
                imagebutton:
                    idle Transform("alvycg8", xsize=500, ysize=281)
                    action [SetVariable("from_gallery", True),Hide("gallery_al"),Jump("alvydream3")]

